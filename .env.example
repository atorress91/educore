# Copy to .env on the VM and fill in real values (never commit .env)
SPRING_DATASOURCE_URL=jdbc:postgresql://DB_HOST:5432/educore
SPRING_DATASOURCE_USERNAME=educore
SPRING_DATASOURCE_PASSWORD=changeme

# Generate a strong secret, e.g.: openssl rand -base64 48
EDUCORE_JWT_SECRET=change-me-to-a-long-random-base64-secret
EDUCORE_JWT_EXPIRATION_MS=86400000

# Optional JVM tuning
JAVA_OPTS=-XX:MaxRAMPercentage=75.0
